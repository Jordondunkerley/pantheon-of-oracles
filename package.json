{
  "name": "pantheon-of-oracles-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Founder-testable desktop prototype for Pantheon of Oracles: The Council Chamber.",
  "author": "Pantheon of Oracles",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "start": "node app/server.js",
    "desktop": "npx electron .",
    "dist:win": "npx electron-builder --win portable",
    "import:oracles": "node scripts/import-oracles.mjs",
    "export:oracle": "node scripts/export-oracle-package.mjs"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "ai.pantheon.councilchamber",
    "productName": "Pantheon of Oracles: The Council Chamber",
    "directories": {
      "output": "dist"
    },
    "files": [
      "app/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ]
    }
  }
}